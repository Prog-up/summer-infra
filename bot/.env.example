# --- Discord (required) ---
# Bot token from https://discord.com/developers/applications → your app → Bot
DISCORD_TOKEN=
# Application (client) ID — same app, "General Information" page
DISCORD_CLIENT_ID=
# Optional: a server ID for instant command registration during development.
# Leave empty to register commands globally (propagation can take ~1h).
DISCORD_GUILD_ID=

# --- Claude (optional but recommended) ---
# Without this, /summary and /ask reply that AI is unavailable, and the push
# summariser falls back to a plain structural diff.
ANTHROPIC_API_KEY=

# --- Where the bot reads the live plan from ---
# Easiest: point at the GitHub repo and let it build the raw URL.
GITHUB_REPOSITORY=prog-up/summer-infra
PLAN_BRANCH=main
PLAN_PATH=plan/index.html
# ...or override with a full raw URL (takes precedence over the three above):
# PLAN_RAW_URL=https://raw.githubusercontent.com/prog-up/summer-infra/main/plan/index.html

# --- Storage ---
# Where /idea and /todo persist. Mount a volume here for durability.
# BOT_DATA_DIR=/data
